# GitHub (optional – increases rate limit from 60 to 5000 req/hr)
# Create at: https://github.com/settings/tokens (no scopes needed for public data)
GITHUB_TOKEN=your_github_pat_here

# GitHub username to fetch data for
GITHUB_USERNAME=purushothaman-web

# Gmail SMTP (for contact form)
# Use a Gmail App Password: https://myaccount.google.com/apppasswords
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here

# CORS Origins (comma-separated list of allowed domains)
# Example: https://purushoth.is-a.dev, http://localhost:5173
CORS_ORIGINS=https://purushoth.is-a.dev, http://localhost:5173, http://localhost:4173

# Server port
PORT=3001
